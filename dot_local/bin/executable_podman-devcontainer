#!/bin/bash
export PODMAN_USERNS=keep-id

# 判断 GPU 是否可用
has_gpu() {
    command -v nvidia-smi >/dev/null 2>&1 && nvidia-smi >/dev/null 2>&1
}

# 拦截 docker info
if [[ "$1" == "info" ]]; then
    if [[ "$2" == "-f" ]]; then
        TEMPLATE="$3"

        # devcontainer 的关键检测点
        if [[ "$TEMPLATE" == *".Runtimes.nvidia"* ]]; then
            if has_gpu; then
                echo "map[path:nvidia-container-runtime runtimeArgs:[]]"
            else
                echo "<no value>"
            fi
            exit 0
        fi
    fi
fi

if [[ "$1" == "run" ]]; then
    shift
    exec podman-remote run --add-host=proxy.anlor.internal:host-gateway "$@"
fi

exec podman-remote "$@"
