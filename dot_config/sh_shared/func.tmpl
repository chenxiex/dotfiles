set-proxy(){
{{- if .container }}
	PROXY_HOST="${1:-host.containers.internal}"
	PROXY_PORT="${2:-10810}"
{{ else }}
	PROXY_HOST="${1:-localhost}"
	PROXY_PORT="${2:-10808}"
{{- end }}

	export http_proxy=http://$PROXY_HOST:$PROXY_PORT
	export https_proxy=$http_proxy
	export ftp_proxy=$http_proxy
	export all_proxy=$http_proxy
	export no_proxy=localhost,127.0.0.0/8,::1

	export HTTP_PROXY=$http_proxy
	export HTTPS_PROXY=$https_proxy
	export FTP_PROXY=$ftp_proxy
	export ALL_PROXY=$all_proxy
	export NO_PROXY=$no_proxy
}

reset-proxy(){
	unset http_proxy
	unset https_proxy
	unset ftp_proxy
	unset all_proxy
	unset no_proxy

	unset HTTP_PROXY
	unset HTTPS_PROXY
	unset FTP_PROXY
	unset ALL_PROXY
	unset NO_PROXY
}

codex(){
	local codex_dir codex_path codex_status

	codex_path=$(
		type -P codex 2>/dev/null ||
		whence -p codex 2>/dev/null ||
		find "$HOME/.vscode-server/extensions" -path '*/openai.chatgpt-*/bin/*/codex' -type f -perm /111 -print -quit 2>/dev/null
	)
	codex_dir=.

	if [[ "$PWD" == "$HOME" ]]; then
		codex_dir="$HOME/opt/build/codex-pwd"
	fi

	(
		cd "$codex_dir" || exit
		if [[ -n "$codex_path" ]]; then
			"$codex_path" "$@"
		else
			command codex "$@"
		fi
	)
	codex_status=$?

	return $status
}

dla(){
	yt-dlp -x --audio-format m4a --audio-quality 0 --embed-thumbnail --add-metadata "${1}"
}

pick_gpu() {
    local gpu_id
    gpu_id=$(nvidia-smi --query-gpu=index,memory.used --format=csv,noheader,nounits \
        | sort -t, -k2 -n \
        | head -n1 \
        | cut -d, -f1)

    export CUDA_VISIBLE_DEVICES="$gpu_id"
    echo "Using GPU $gpu_id"
}
