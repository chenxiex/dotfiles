#!/usr/bin/bash
{{- if (and (eq .chezmoi.hostname "anlorsp-main") (eq .chezmoi.os "linux")) }}
cd ~/.config/ibus/
rsync -a --delete \
	--exclude='user.yaml' \
	--exclude='installation.yaml' \
	--exclude='build' \
	--exclude='*.userdb' \
	--exclude='*.custom.yaml' \
	--exclude='*.gram' \
	rime_source/oh-my-rime/ ./rime
rsync -a rime_source/rime_custom/ ./rime
{{- end }}
