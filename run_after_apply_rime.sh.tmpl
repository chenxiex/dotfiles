{{- if (and (eq .chezmoi.hostname "anlorsp-main") (eq .chezmoi.os "linux")) -}}
#!/usr/bin/bash
RIME_PATH=~/.config/rime
INSTALL_PATHS=(
  "$HOME/.config/ibus/rime"
  "$HOME/.var/app/org.fcitx.Fcitx5/data/fcitx5/rime"
  "$HOME/.local/share/fcitx5/rime"
)

for install_path in "${INSTALL_PATHS[@]}"; do
  mkdir -p "$install_path"
  ln -sf --relative -t "$install_path" "$RIME_PATH"/oh-my-rime/* "$RIME_PATH"/rime_custom/* "$RIME_PATH"/wanxiang/*
done
{{- end }}
